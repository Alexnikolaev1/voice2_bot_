# Google Gemini API (AI Studio → API key)
GEMINI_API_KEY=

# Optional TTS models (defaults: gemini-3.1-flash-tts-preview, gemini-2.5-flash-preview-tts)
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# GEMINI_TTS_FALLBACK_MODEL=gemini-2.5-flash-preview-tts

# MAX Bot (platform-api.max.ru)
MAX_BOT_TOKEN=

# Optional: validate webhook (header X-Max-Bot-Api-Secret)
MAX_WEBHOOK_SECRET=

# Optional: override API host
# MAX_API_BASE=https://platform-api.max.ru

# Vercel KV (auto-filled when KV is linked in Vercel)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
